#include <stdio.h>
#include <stdlib.h>

struct node {
    int data;
    struct node *next;
};

typedef struct node *NODE;

// 1. Create a new node
NODE createNodeInCLL(int data) {
    NODE temp = (NODE)malloc(sizeof(struct node));
    temp->data = data;
    temp->next = NULL;
    return temp;
}

// 2. Create CLL with n nodes
NODE createCLL(int n) {
    NODE first = NULL, last = NULL, temp;
    int x, i;
    for (i = 0; i < n; i++) {
        scanf("%d", &x);
        temp = createNodeInCLL(x);
        if (first == NULL) {
            first = temp;
            first->next = first;
            last = first;
        } else {
            last->next = temp;
            temp->next = first;
            last = temp;
        }
    }
    return first;
}

// 3. Insert at position
NODE insertAtPositionInCLL(NODE first, int pos, int x) {
    NODE temp, curr;
    temp = createNodeInCLL(x);
    if (pos == 1) {
        if (first == NULL) {
            temp->next = temp;
            return temp;
        }
        curr = first;
        while (curr->next != first) curr = curr->next;
        temp->next = first;
        curr->next = temp;
        return temp;
    }
    curr = first;
    for (int i = 1; i < pos - 1; i++) {
        curr = curr->next;
        if (curr == first) {
            printf("Position not found\n");
            return first;
        }
    }
    temp->next = curr->next;
    curr->next = temp;
    return first;
}

// 4. Delete at position
NODE deleteAtPositionInCLL(NODE first, int pos) {
    if (first == NULL) return NULL;
    NODE curr = first, prev = NULL;
    if (pos == 1) {
        printf("Deleted element: %d\n", first->data);
        if (first->next == first) {
            free(first);
            return NULL;
        }
        while (curr->next != first) curr = curr->next;
        curr->next = first->next;
        NODE temp = first;
        first = first->next;
        free(temp);
        return first;
    }
    for (int i = 1; i < pos; i++) {
        prev = curr;
        curr = curr->next;
        if (curr == first) {
            printf("Position not found\n");
            return first;
        }
    }
    printf("Deleted element: %d\n", curr->data);
    prev->next = curr->next;
    free(curr);
    return first;
}

// 5. Traverse/Display
void traverseListInCLL(NODE first) {
    if (first == NULL) {
        printf("CLL is empty\n");
        return;
    }
    NODE temp = first;
    do {
        printf("%d -> ", temp->data);
        temp = temp->next;
    } while (temp != first);
    printf("\n");
}

