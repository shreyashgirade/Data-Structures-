// 7. Concatenate (Filling in your missing logic)
NODE concatCLL(NODE first, NODE second) {
    if (first == NULL) return second;
    if (second == NULL) return first;
    
    NODE t1 = first, t2 = second;
    while (t1->next != first) t1 = t1->next;
    while (t2->next != second) t2 = t2->next;
    
    t1->next = second;
    t2->next = first;
    return first;
}

int main() {
    NODE first = NULL, second = NULL;
    int x, pos, op, n;

    while (1) {
        printf("1.Create 2.Insert 3.Delete 4.Display 5.Reverse 6.Concat 7.Exit\nchoice: ");
        if (scanf("%d", &op) != 1) break;
        switch (op) {
            case 1:
                printf("How many nodes? ");
                scanf("%d", &n);
                first = createCLL(n);
                break;
            case 2:
                printf("Position: ");
                scanf("%d", &pos);
                if (pos <= 0) printf("Position not found\n");
                else {
                    printf("Element: ");
                    scanf("%d", &x);
                    first = insertAtPositionInCLL(first, pos, x);
                }
                break;
            case 3:
                if (first == NULL) printf("CLL is empty\n");
                else {
                    printf("Position: ");
                    scanf("%d", &pos);
                    first = deleteAtPositionInCLL(first, pos);
                }
                break;
            case 4:
                if (first == NULL) printf("CLL is empty\n");
                else {
                    printf("Elements in CLL are: ");
                    traverseListInCLL(first);
                }
                break;
            case 5:
                if (first == NULL) printf("CLL is empty\n");
                else {
                    first = reverseCLL(first);
                    printf("CLL reversed\n");
                    traverseListInCLL(first);
                }
                break;
            case 6:
                printf("Creating second CLL to concatenate...\nHow many nodes in second CLL? ");
                scanf("%d", &n);
                second = createCLL(n);
                first = concatCLL(first, second);
                printf("Concatenated CLL:\n");
                traverseListInCLL(first);
                break;
            case 7:
                exit(0);
        }
    }
    return 0;
}
